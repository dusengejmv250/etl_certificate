# Copy this file to .env and fill in real values. Never commit .env to git.

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=etl_app
DB_PASSWORD=change_me
DB_NAME=etl_certificate_portal

# --- Session ---
# Any long random string. Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_this_with_a_long_random_string

# --- Email (SMTP via Nodemailer) ---
# Works with Gmail (use an App Password, not your normal password — see README),
# or any SMTP provider (SendGrid, Mailgun, Zoho, your own mail server, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-sending-address@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM="École Technique Libre <your-sending-address@gmail.com>"

# --- App ---
PORT=3000
# The real public URL of your deployed app (used to build QR/verify/sign links)
BASE_URL=http://localhost:3000

# The one email allowed to log in as Administrator (must match the seeded admin user)
ADMIN_EMAIL=drmarvinltd@gmail.com
ADMIN_PASSWORD=Duse123@
ADMIN_NAME="System Administrator"
